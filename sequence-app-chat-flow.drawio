                <mxCell id="db_session2" value="chat_session表&#xa;(会话表)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#6FA3FF;strokeColor=#6FA3FF;fontColor=#FFFFFF;fontSize=12;" parent="1" vertex="1">
