                <mxCell id="section1" value="【流程1: 发送消息 / 流式对话生成代码】" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontColor=#333333;fontStyle=1;" parent="1" vertex="1">
