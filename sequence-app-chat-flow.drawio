                <mxCell id="svc1" value="AppServiceImpl&#xa;(服务层)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#22D3EE;strokeColor=#22D3EE;fontColor=#FFFFFF;fontSize=14;" parent="1" vertex="1">
