                <mxCell id="db_user2" value="user表&#xa;(用户表)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#6FA3FF;strokeColor=#6FA3FF;fontColor=#FFFFFF;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="1360" y="70" width="120" height="60" as="geometry"/>
                </mxCell>

                <mxCell id="db_app2" value="app表&#xa;(应用表)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#6FA3FF;strokeColor=#6FA3FF;fontColor=#FFFFFF;fontSize=13;" parent="1" vertex="1">
                    <mxGeometry x="1680" y="70" width="120" height="60" as="geometry"/>
