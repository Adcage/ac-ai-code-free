                    <mxGeometry x="635" y="280" width="10" height="1460" as="geometry"/>
                </mxCell>

                <!-- user表激活条 -->
                <mxCell id="act5" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#6FA3FF;strokeColor=#6FA3FF;" parent="1" vertex="1">
                    <mxGeometry x="1415" y="430" width="10" height="60" as="geometry"/>
                </mxCell>

                <!-- app表激活条1 (插入) -->
                <mxCell id="act6" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#6FA3FF;strokeColor=#6FA3FF;" parent="1" vertex="1">
                    <mxGeometry x="1735" y="780" width="10" height="60" as="geometry"/>
                </mxCell>

                <!-- app表激活条2 (回查) -->
                <mxCell id="act7" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#6FA3FF;strokeColor=#6FA3FF;" parent="1" vertex="1">
                    <mxGeometry x="1735" y="1060" width="10" height="60" as="geometry"/>
                </mxCell>

                <!-- ==================== 消息序列（含目的说明） ==================== -->

                <!-- ===== 1: 用户点击创建应用按钮 ===== -->
                <mxCell id="m1" value="1: 点击【创建应用】按钮" style="endArrow=classic;html=1;strokeColor=#3366CC;strokeWidth=2;fontSize=13;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="65" y="200" as="sourcePoint"/>
                        <mxPoint x="250" y="200" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m1_note" value="目的: 用户在页面上发起创建&#xa;应用的请求，携带initPrompt" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="70" y="210" width="170" height="35" as="geometry"/>
                </mxCell>

                <!-- ===== 2: 前端发送POST /app/add请求 ===== -->
                <mxCell id="m2" value="2: POST /app/add {initPrompt: &quot;...&quot;}" style="endArrow=classic;html=1;strokeColor=#3366CC;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="255" y="260" as="sourcePoint"/>
                        <mxPoint x="440" y="260" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m2_note" value="目的: 前端将用户输入的初始化Prompt&#xa;封装为请求体，调用后端创建应用接口" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="260" y="270" width="200" height="35" as="geometry"/>
                </mxCell>

                <!-- ===== 3: Controller参数校验 ===== -->
                <mxCell id="m3" value="3: 校验参数(initPrompt不能为空)" style="endArrow=classic;html=1;strokeColor=#27BC9F;strokeWidth=2;fontSize=13;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="440" y="320" as="sourcePoint"/>
                        <mxPoint x="640" y="320" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_note" value="目的: Controller层参数校验，&#xa;确保initPrompt必填参数不为空，&#xa;防止无效请求进入业务层" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="660" y="310" width="280" height="45" as="geometry"/>
                </mxCell>

                <!-- ===== 4: Service获取当前登录用户 ===== -->
                <mxCell id="m4" value="4: getLoginUser(request)" style="endArrow=classic;html=1;strokeColor=#22D3EE;strokeWidth=2;fontSize=13;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="640" y="380" as="sourcePoint"/>
                        <mxPoint x="1420" y="380" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m4_note" value="目的: 从请求上下文中获取当前登录用户&#xa;信息，用于后续设置应用创建者userId" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="660" y="370" width="280" height="35" as="geometry"/>
                </mxCell>

                <!-- ===== 5: user表查询 ===== -->
                <mxCell id="m5" value="5: SELECT * FROM user&#xa;WHERE id=? AND isDelete=0" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="640" y="440" as="sourcePoint"/>
                        <mxPoint x="1420" y="440" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m5_note" value="目的: 根据会话中的userId查询用户表，&#xa;验证用户身份有效性，确保用户存在且未删除" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="660" y="430" width="280" height="35" as="geometry"/>
                </mxCell>

                <!-- ===== 6: 返回User对象 ===== -->
                <mxCell id="m6" value="6: 返回 loginUser (用户对象)" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=13;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="1420" y="490" as="sourcePoint"/>
                        <mxPoint x="640" y="490" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- ===== 7: Service构造App对象 ===== -->
                <mxCell id="m7_note" value="7: 构造App对象&#xa;● appName = initPrompt前12字符&#xa;● codeGenType = &quot;multi-file&quot;(默认多文件)&#xa;● userId = loginUser.id&#xa;● id = 雪花算法自动生成&#xa;功能: 将前端请求参数转换为实体对象，&#xa;设置默认值后准备持久化" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#FF9800;fontColor=#333333;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="660" y="520" width="320" height="100" as="geometry"/>
                </mxCell>

                <!-- ===== 8: Service调用insert保存 ===== -->
                <mxCell id="m8" value="8: appMapper.insert(app)" style="endArrow=classic;html=1;strokeColor=#22D3EE;strokeWidth=2;fontSize=13;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="640" y="660" as="sourcePoint"/>
                        <mxPoint x="1740" y="660" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m8_note" value="目的: 将构造好的App实体对象&#xa;持久化到数据库app表中" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="660" y="650" width="260" height="35" as="geometry"/>
                </mxCell>

                <!-- ===== 9: app表INSERT ===== -->
                <mxCell id="m9" value="9: INSERT INTO app&#xa;(appName, initPrompt, codeGenType,&#xa;userId, createTime, updateTime, ...)&#xa;VALUES (?, ?, ?, ?, NOW(), NOW(), ...)" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=11;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="640" y="730" as="sourcePoint"/>
                        <mxPoint x="1740" y="730" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m9_note" value="目的: 向app表插入一条新的应用记录，&#xa;包含appName/initPrompt/codeGenType/userId等字段，&#xa;id由雪花算法生成，createTime/updateTime由数据库自动填充" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1100" y="750" width="340" height="50" as="geometry"/>
                </mxCell>

                <!-- ===== 10: 返回插入结果 ===== -->
                <mxCell id="m10" value="10: 返回插入结果 (1 row affected)" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=13;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="1740" y="810" as="sourcePoint"/>
                        <mxPoint x="640" y="810" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- ===== 11: 回查完整App对象 ===== -->
                <mxCell id="m11" value="11: appService.getById(appId)&#xa;根据插入后的ID查询完整应用信息" style="endArrow=classic;html=1;strokeColor=#22D3EE;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="640" y="880" as="sourcePoint"/>
                        <mxPoint x="1740" y="880" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m11_note" value="目的: 插入后ID已生成，需要回查app表获取&#xa;包含id/createTime/updateTime等&#xa;数据库自动填充字段的完整App对象，&#xa;用于后续组装VO返回给前端" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1100" y="900" width="320" height="60" as="geometry"/>
                </mxCell>

                <!-- ===== 12: SELECT app ===== -->
                <mxCell id="m12" value="12: SELECT * FROM app&#xa;WHERE id=? AND isDelete=0" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="640" y="990" as="sourcePoint"/>
                        <mxPoint x="1740" y="990" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m12_note" value="目的: 根据雪花ID精确查找刚插入的app记录，&#xa;同时过滤已删除记录(isDelete=0)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1100" y="1010" width="320" height="35" as="geometry"/>
                </mxCell>

                <!-- ===== 13: 返回完整App对象 ===== -->
                <mxCell id="m13" value="13: 返回完整App对象&#xa;(含id, createTime, updateTime等自动填充字段)" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=12;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="1740" y="1070" as="sourcePoint"/>
                        <mxPoint x="640" y="1070" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- ===== 14: 返回appId给Controller ===== -->
                <mxCell id="m14" value="14: 返回 app.getId() (appId)" style="endArrow=classic;html=1;strokeColor=#22D3EE;strokeWidth=2;fontSize=13;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="640" y="1140" as="sourcePoint"/>
                        <mxPoint x="440" y="1140" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m14_note" value="目的: Service层将新创建的应用ID&#xa;返回给Controller，作为创建成功的标识" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="460" y="1150" width="260" height="35" as="geometry"/>
                </mxCell>

                <!-- ===== 15: Controller返回统一响应 ===== -->
                <mxCell id="m15" value="15: 返回 BaseResponse&lt;Long&gt;&#xa;{code:0, data: appId, message:&quot;ok&quot;}" style="endArrow=classic;html=1;strokeColor=#27BC9F;strokeWidth=2;fontSize=12;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="440" y="1210" as="sourcePoint"/>
                        <mxPoint x="255" y="1210" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m15_note" value="目的: Controller将appId封装为统一响应&#xa;格式BaseResponse返回，code=0表示成功" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="260" y="1220" width="270" height="35" as="geometry"/>
                </mxCell>

                <!-- ===== 16: 前端跳转到对话页 ===== -->
                <mxCell id="m16" value="16: 收到appId，跳转到应用对话页" style="endArrow=classic;html=1;strokeColor=#3366CC;strokeWidth=2;fontSize=13;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="255" y="1280" as="sourcePoint"/>
                        <mxPoint x="65" y="1280" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m16_note" value="目的: 前端收到创建成功响应后，&#xa;使用appId路由到该应用的对话界面" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="70" y="1290" width="230" height="35" as="geometry"/>
                </mxCell>

                <!-- ===== 17: 显示新应用对话页面 ===== -->
                <mxCell id="m17" value="17: 显示新建应用的对话页面&#xa;(包含initPrompt作为对话上下文)" style="endArrow=classic;html=1;strokeColor=#3366CC;strokeWidth=2;fontSize=12;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="255" y="1350" as="sourcePoint"/>
                        <mxPoint x="65" y="1350" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m17_note" value="目的: 用户进入对话界面，可以看到应用名称，&#xa;应用的initPrompt将作为AI对话的系统提示词" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="70" y="1360" width="290" height="35" as="geometry"/>
                </mxCell>

                <!-- ===== 数据库表字段说明注释 ===== -->
                <mxCell id="db_note_user" value="user表字段:&#xa;id(雪花ID), userAccount,&#xa;userPassword, userName, userAvatar,&#xa;userProfile, userRole,&#xa;vipExpireTime, vipCode, ...&#xa;功能: 存储用户账号信息与权限角色" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F4FD;strokeColor=#6FA3FF;fontColor=#333333;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="160" width="240" height="110" as="geometry"/>
                </mxCell>

                <mxCell id="db_note_app" value="app表字段:&#xa;id(雪花ID), appName, cover,&#xa;initPrompt(初始化提示词),&#xa;codeGenType(代码生成类型),&#xa;deployKey, deployedTime,&#xa;priority, userId(创建者), ...&#xa;功能: 存储AI编程应用的配置信息" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F4FD;strokeColor=#6FA3FF;fontColor=#333333;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="1620" y="160" width="280" height="120" as="geometry"/>
                </mxCell>

            </root>
        </mxGraphModel>
    </diagram>

    <diagram id="create-session-flow" name="2-创建会话流程">
        <mxGraphModel dx="2600" dy="2200" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2600" pageHeight="2400" math="0" shadow="1">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>

                <!-- ==================== 参与者对象 ==================== -->

                <mxCell id="actor2" value="&lt;font color=&quot;#0f0f0f&quot;&gt;用户&lt;/font&gt;" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#FFFFFF;fontSize=16;" parent="1" vertex="1">
                    <mxGeometry x="40" y="60" width="40" height="80" as="geometry"/>
                </mxCell>

                <mxCell id="vue2" value="前端页面&#xa;(Vue3)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#3366CC;strokeColor=#3366CC;fontColor=#FFFFFF;fontSize=14;" parent="1" vertex="1">
                    <mxGeometry x="200" y="80" width="100" height="40" as="geometry"/>
                </mxCell>

