                    </mxGeometry>
                </mxCell>

                <mxCell id="ll2_6" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#666666;strokeWidth=2;" parent="1" source="db_app2" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="1740" y="130" as="sourcePoint"/>
                        <mxPoint x="1740" y="2300" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <mxCell id="ll2_7" value="" style="endArrow=none;dashed=1;html=1;strokeColor=#666666;strokeWidth=2;" parent="1" source="db_session2" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="2060" y="130" as="sourcePoint"/>
