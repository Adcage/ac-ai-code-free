                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_10_note" value="目的: 校验sessionId对应的会话确实属于&#xa;当前用户和当前应用，防止跨会话越权访问" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="740" width="320" height="40" as="geometry"/>
                </mxCell>

                <!-- 11 -->
                <mxCell id="m3_11" value="11: SELECT * FROM chat_session&#xa;WHERE id=? AND appId=?&#xa;AND userId=? AND isDelete=0" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=11;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="620" y="780" as="sourcePoint"/>
                        <mxPoint x="1820" y="780" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_11_note" value="目的: 三重条件校验——确保会话ID、应用ID、&#xa;用户ID全部匹配，任何不匹配则抛出异常" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1100" y="790" width="340" height="40" as="geometry"/>
                </mxCell>

                <!-- 12 -->
                <mxCell id="m3_12" value="12: 返回ChatSession对象 (校验通过)" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=13;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="1820" y="840" as="sourcePoint"/>
                        <mxPoint x="620" y="840" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- 13 -->
                <mxCell id="m3_13" value="13: saveHistoryMessage&#xa;(type=&quot;user&quot;, status=&quot;success&quot;)&#xa;保存用户消息" style="endArrow=classic;html=1;strokeColor=#22D3EE;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="620" y="880" as="sourcePoint"/>
                        <mxPoint x="2060" y="880" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_13_note" value="目的: 在调用AI之前先将用户输入的消息&#xa;持久化到chat_history表，确保消息不丢失，&#xa;同时用于对话上下文的构建" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="870" width="310" height="50" as="geometry"/>
                </mxCell>

                <!-- 14 -->
                <mxCell id="m3_14" value="14: INSERT INTO chat_history&#xa;(sessionId, seqNo, message,&#xa;messageType=&quot;user&quot;,&#xa;status=&quot;success&quot;, appId, userId, ...)" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=11;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="620" y="940" as="sourcePoint"/>
                        <mxPoint x="2060" y="940" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_14_note" value="目的: 向chat_history表写入用户消息记录，&#xa;seqNo通过getNextSeqNo方法自增，&#xa;messageType=&quot;user&quot;标识消息来源，&#xa;status=&quot;success&quot;表示用户消息直接成功" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="950" width="340" height="50" as="geometry"/>
                </mxCell>

                <!-- 15 -->
                <mxCell id="m3_15" value="15: 返回插入成功 (1 row affected)" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=13;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="2060" y="1000" as="sourcePoint"/>
                        <mxPoint x="620" y="1000" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- 16 -->
                <mxCell id="m3_16" value="16: updateSessionSummary(sessionId)&#xa;更新messageCount和lastMessageTime" style="endArrow=classic;html=1;strokeColor=#22D3EE;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="620" y="1040" as="sourcePoint"/>
                        <mxPoint x="1820" y="1040" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_16_note" value="目的: 保存用户消息后同步更新chat_session表，&#xa;将messageCount+1并更新lastMessageTime，&#xa;便于会话列表展示最新状态和消息数" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="1050" width="340" height="50" as="geometry"/>
                </mxCell>

                <!-- 17 -->
                <mxCell id="m3_17" value="17: UPDATE chat_session&#xa;SET messageCount=messageCount+1,&#xa;lastMessageTime=NOW()&#xa;WHERE id=?" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=11;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="620" y="1100" as="sourcePoint"/>
                        <mxPoint x="1820" y="1100" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_17_note" value="目的: 更新chat_session的消息计数和最后消息时间，&#xa;使会话列表能按最近活动时间排序" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="1110" width="300" height="35" as="geometry"/>
                </mxCell>

                <!-- 18 -->
                <mxCell id="m3_18" value="18: 更新成功" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=13;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="1820" y="1150" as="sourcePoint"/>
                        <mxPoint x="620" y="1150" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- 19 -->
                <mxCell id="m3_19" value="19: aiCodeGeneratorFacade&#xa;.generateAndSaveCodeStream&#xa;(message, codeGenTypeEnum, appId)" style="endArrow=classic;html=1;strokeColor=#22D3EE;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="620" y="1200" as="sourcePoint"/>
                        <mxPoint x="820" y="1200" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_19_note" value="目的: 调用AI代码生成门面服务，&#xa;基于应用的initPrompt和用户消息，&#xa;使用LangChain4j调用大模型流式生成代码，&#xa;返回Flux&lt;String&gt;流式响应" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#8B5CF6;fontColor=#333333;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="840" y="1180" width="280" height="55" as="geometry"/>
                </mxCell>

                <!-- 20 -->
                <mxCell id="m3_20" value="20: 返回 Flux&lt;String&gt;&#xa;流式代码片段(逐个chunk)" style="endArrow=classic;html=1;strokeColor=#8B5CF6;strokeWidth=2;fontSize=12;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="820" y="1270" as="sourcePoint"/>
                        <mxPoint x="620" y="1270" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_20_note" value="目的: AI门面返回流式响应，&#xa;每个chunk是一小段生成的代码，&#xa;会在流完成后整体汇总保存" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#8B5CF6;fontColor=#333333;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="840" y="1280" width="280" height="45" as="geometry"/>
                </mxCell>

                <!-- 21 -->
                <mxCell id="m3_21" value="21: [流完成] saveHistoryMessage&#xa;(type=&quot;ai&quot;, status=&quot;success&quot;,&#xa;记录latencyMs)" style="endArrow=classic;html=1;strokeColor=#22D3EE;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="620" y="1360" as="sourcePoint"/>
                        <mxPoint x="2060" y="1360" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_21_note" value="目的: AI流式生成完成后(doOnComplete回调)，&#xa;将AI生成的完整响应内容保存到chat_history，&#xa;同时记录响应耗时latencyMs和token消耗量" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="1370" width="340" height="50" as="geometry"/>
                </mxCell>

                <!-- 22 -->
                <mxCell id="m3_22" value="22: INSERT INTO chat_history&#xa;(sessionId, seqNo, message,&#xa;messageType=&quot;ai&quot;, status=&quot;success&quot;,&#xa;latencyMs=耗时, inputTokens, outputTokens, ...)" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=11;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="620" y="1430" as="sourcePoint"/>
                        <mxPoint x="2060" y="1430" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_22_note" value="目的: 将AI的完整响应内容写入chat_history表，&#xa;messageType=&quot;ai&quot;区分AI消息，latencyMs记录性能数据，&#xa;inputTokens/outputTokens记录token消耗用于计费统计" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="1440" width="340" height="50" as="geometry"/>
                </mxCell>

                <!-- 23 -->
                <mxCell id="m3_23" value="23: SSE流式返回给前端&#xa;meta事件: {sessionId: xxx}&#xa;data事件: {d: chunk1}&#xa;data事件: {d: chunk2}&#xa;... (循环)&#xa;done事件: [DONE]" style="endArrow=classic;html=1;strokeColor=#27BC9F;strokeWidth=2;fontSize=12;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="420" y="1520" as="sourcePoint"/>
                        <mxPoint x="235" y="1520" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_23_note" value="目的: Controller将Flux流逐步包装为SSE事件推送到前端:&#xa;● meta事件: 携带sessionId，前端可用于会话绑定&#xa;● data事件: 每个chunk是一小段生成的代码&#xa;● done事件: 标识流式生成完成&#xa;前端逐步拼接chunks实现打字机效果展示" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="240" y="1540" width="380" height="90" as="geometry"/>
                </mxCell>

                <!-- 24 -->
                <mxCell id="m3_24" value="24: 逐步渲染AI生成代码&#xa;(打字机效果，流式显示)" style="endArrow=classic;html=1;strokeColor=#3366CC;strokeWidth=2;fontSize=12;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="235" y="1660" as="sourcePoint"/>
                        <mxPoint x="65" y="1660" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_24_note" value="目的: 前端通过EventSource接收SSE事件，&#xa;将每个chunk追加到代码显示区域，&#xa;实现AI逐行生成代码的视觉体验" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="70" y="1670" width="280" height="45" as="geometry"/>
                </mxCell>

                <!-- ==================== 流程2: 查询会话列表 ==================== -->

