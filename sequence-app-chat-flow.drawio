                <!-- ==================== 流程3: 查询聊天历史 ==================== -->

                <mxCell id="section3" value="【流程3: 分页查询聊天历史】" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontColor=#333333;fontStyle=1;" parent="1" vertex="1">
