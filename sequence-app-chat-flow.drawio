                <mxCell id="m3_33_note" value="目的: 前端将会话列表渲染到侧边栏，&#xa;每个会话显示标题、消息数和最后活动时间，&#xa;用户可点击切换到不同会话" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="70" y="2320" width="280" height="45" as="geometry"/>
