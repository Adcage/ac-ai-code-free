                <mxCell id="db_user1" value="user表&#xa;(用户表)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#6FA3FF;strokeColor=#6FA3FF;fontColor=#FFFFFF;fontSize=13;" parent="1" vertex="1">
