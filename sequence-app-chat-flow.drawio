                    </mxGeometry>
                </mxCell>

                <!-- ==================== 激活条 ==================== -->

                <mxCell id="act2_1" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="55" y="180" width="10" height="1980" as="geometry"/>
                </mxCell>

                <mxCell id="act2_2" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#3366CC;strokeColor=#3366CC;" parent="1" vertex="1">
                    <mxGeometry x="245" y="195" width="10" height="1940" as="geometry"/>
                </mxCell>

                <mxCell id="act2_3" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#27BC9F;strokeColor=#27BC9F;" parent="1" vertex="1">
                    <mxGeometry x="435" y="220" width="10" height="1860" as="geometry"/>
                </mxCell>

                <mxCell id="act2_4" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#22D3EE;strokeColor=#22D3EE;" parent="1" vertex="1">
                    <mxGeometry x="635" y="260" width="10" height="1720" as="geometry"/>
                </mxCell>

                <!-- user表激活条 -->
                <mxCell id="act2_5" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#6FA3FF;strokeColor=#6FA3FF;" parent="1" vertex="1">
                    <mxGeometry x="1415" y="390" width="10" height="60" as="geometry"/>
                </mxCell>

                <!-- app表激活条 -->
                <mxCell id="act2_6" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#6FA3FF;strokeColor=#6FA3FF;" parent="1" vertex="1">
                    <mxGeometry x="1735" y="590" width="10" height="60" as="geometry"/>
                </mxCell>

                <!-- chat_session表激活条1 (统计) -->
                <mxCell id="act2_7" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#6FA3FF;strokeColor=#6FA3FF;" parent="1" vertex="1">
                    <mxGeometry x="2055" y="750" width="10" height="60" as="geometry"/>
                </mxCell>

                <!-- chat_session表激活条2 (插入) -->
                <mxCell id="act2_8" value="" style="html=1;points=[];perimeter=orthogonalPerimeter;fillColor=#6FA3FF;strokeColor=#6FA3FF;" parent="1" vertex="1">
                    <mxGeometry x="2055" y="1000" width="10" height="60" as="geometry"/>
                </mxCell>

                <!-- ==================== 数据库表字段说明 ==================== -->

                <mxCell id="db_note_user2" value="user表字段:&#xa;id(雪花ID), userAccount,&#xa;userPassword, userName, userAvatar,&#xa;userProfile, userRole,&#xa;vipExpireTime, vipCode, ...&#xa;功能: 存储用户账号信息与权限角色" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F4FD;strokeColor=#6FA3FF;fontColor=#333333;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="160" width="240" height="110" as="geometry"/>
                </mxCell>

                <mxCell id="db_note_app2" value="app表字段:&#xa;id(雪花ID), appName, cover,&#xa;initPrompt(初始化提示词),&#xa;codeGenType(代码生成类型),&#xa;deployKey, priority, userId, ...&#xa;功能: 存储AI编程应用配置信息" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F4FD;strokeColor=#6FA3FF;fontColor=#333333;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="1620" y="160" width="260" height="110" as="geometry"/>
                </mxCell>

                <mxCell id="db_note_session2" value="chat_session表字段:&#xa;id(雪花ID), appId(应用ID),&#xa;userId(创建者ID), title(会话标题),&#xa;messageCount(消息数),&#xa;modelName(模型名称),&#xa;lastMessageTime(最后消息时间)&#xa;功能: 存储用户与AI的会话元信息" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F4FD;strokeColor=#6FA3FF;fontColor=#333333;fontSize=11;" parent="1" vertex="1">
                    <mxGeometry x="1940" y="160" width="250" height="120" as="geometry"/>
                </mxCell>

                <!-- ==================== 消息序列（含目的说明） ==================== -->

                <!-- 方式A标注 -->
                <mxCell id="branch_a" value="【方式A: 手动创建会话】 POST /app/chat/session/create" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#FF9800;fontColor=#666666;fontSize=13;fontStyle=1;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="60" y="190" width="400" height="30" as="geometry"/>
                </mxCell>

                <!-- 1: 用户点击新建会话 -->
                <mxCell id="m2_1" value="1: 点击【新建会话】按钮" style="endArrow=classic;html=1;strokeColor=#3366CC;strokeWidth=2;fontSize=13;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="65" y="250" as="sourcePoint"/>
                        <mxPoint x="250" y="250" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m2_1_note" value="目的: 在某应用下发起一个新会话，&#xa;会话是用户与AI对话的基本单元" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="70" y="260" width="230" height="35" as="geometry"/>
                </mxCell>

                <!-- 2: 前端发送POST -->
                <mxCell id="m2_2" value="2: POST /app/chat/session/create&#xa;{appId: 123}" style="endArrow=classic;html=1;strokeColor=#3366CC;strokeWidth=2;fontSize=13;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="255" y="310" as="sourcePoint"/>
                        <mxPoint x="440" y="310" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m2_2_note" value="目的: 将应用ID发送到后端，&#xa;请求在该应用下创建新会话" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="260" y="320" width="220" height="35" as="geometry"/>
                </mxCell>

                <!-- 3: Controller调用Service -->
                <mxCell id="m2_3" value="3: appService.createChatSession&#xa;(appId, loginUser)" style="endArrow=classic;html=1;strokeColor=#27BC9F;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="440" y="370" as="sourcePoint"/>
                        <mxPoint x="640" y="370" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m2_3_note" value="目的: Controller将请求委派给Service层&#xa;执行创建会话的业务逻辑" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="460" y="380" width="230" height="35" as="geometry"/>
                </mxCell>

                <!-- 4: 获取登录用户 -->
                <mxCell id="m2_4" value="4: getLoginUser(request)&#xa;查询当前登录用户信息" style="endArrow=classic;html=1;strokeColor=#22D3EE;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="640" y="430" as="sourcePoint"/>
                        <mxPoint x="1420" y="430" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m2_4_note" value="目的: 从请求上下文获取当前登录用户，&#xa;验证身份并用于后续会话归属（userId）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="660" y="420" width="280" height="35" as="geometry"/>
                </mxCell>

                <!-- 5: user表查询 -->
                <mxCell id="m2_5" value="5: SELECT * FROM user&#xa;WHERE id=? AND isDelete=0" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="640" y="470" as="sourcePoint"/>
                        <mxPoint x="1420" y="470" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m2_5_note" value="目的: 从user表查询登录用户完整信息，&#xa;确保用户存在且未被逻辑删除" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1000" y="480" width="260" height="35" as="geometry"/>
                </mxCell>

                <!-- 6: 返回User对象 -->
                <mxCell id="m2_6" value="6: 返回 loginUser (用户对象)" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=12;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="1420" y="520" as="sourcePoint"/>
                        <mxPoint x="640" y="520" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- 7: 校验应用存在性和权限 -->
                <mxCell id="m2_7" value="7: getAndCheckApp(appId, loginUser)&#xa;校验应用存在且属于当前用户" style="endArrow=classic;html=1;strokeColor=#22D3EE;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="640" y="570" as="sourcePoint"/>
                        <mxPoint x="1740" y="570" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m2_7_note" value="目的: 校验appId指向的应用确实存在、&#xa;且创建者就是当前登录用户(或管理员)，&#xa;防止越权操作他人应用下的会话" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="530" width="280" height="45" as="geometry"/>
                </mxCell>

                <!-- 8: app表查询 -->
                <mxCell id="m2_8" value="8: SELECT * FROM app&#xa;WHERE id=? AND userId=&#xa;AND isDelete=0" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="640" y="630" as="sourcePoint"/>
                        <mxPoint x="1740" y="630" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m2_8_note" value="目的: 查询app表验证应用存在性，&#xa;同时检查userId确保权限归属" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1100" y="640" width="260" height="35" as="geometry"/>
                </mxCell>

                <!-- 9: 返回App对象 -->
                <mxCell id="m2_9" value="9: 返回App对象 (校验通过)" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=13;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="1740" y="690" as="sourcePoint"/>
                        <mxPoint x="640" y="690" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- 10: 统计会话数 -->
                <mxCell id="m2_10" value="10: chatSessionMapper.selectCountByQuery&#xa;统计该应用下已有会话数" style="endArrow=classic;html=1;strokeColor=#22D3EE;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="640" y="740" as="sourcePoint"/>
                        <mxPoint x="2060" y="740" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m2_10_note" value="目的: 统计当前用户在该应用下已有多少会话，&#xa;用于自动生成会话标题序号(&quot;新会话 N&quot;)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1100" y="750" width="320" height="35" as="geometry"/>
                </mxCell>

                <!-- 11: chat_session表统计查询 -->
                <mxCell id="m2_11" value="11: SELECT COUNT(*) FROM chat_session&#xa;WHERE userId=? AND appId=?&#xa;AND isDelete=0" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=11;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="640" y="800" as="sourcePoint"/>
                        <mxPoint x="2060" y="800" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m2_11_note" value="目的: 从chat_session表统计该用户在该应用下&#xa;的有效会话(未删除)数量，返回数值如3" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="810" width="300" height="35" as="geometry"/>
                </mxCell>

                <!-- 12: 返回会话数量 -->
                <mxCell id="m2_12" value="12: 返回 count (如: 3)&#xa;表示该用户此应用已有3个会话" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=12;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="2060" y="860" as="sourcePoint"/>
                        <mxPoint x="640" y="860" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- 13: 构造ChatSession对象 -->
                <mxCell id="m2_13_note" value="13: 构造ChatSession对象并设置属性&#xa;● id = 雪花算法生成&#xa;● title = &quot;新会话 N&quot; (N=count+1=4)&#xa;● appId = 当前应用ID&#xa;● userId = 当前用户ID&#xa;● messageCount = 0 (初始消息数为0)&#xa;● modelName = 应用配置的模型名&#xa;功能: 将上述属性组装成ChatSession实体&#xa;准备持久化到数据库" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#FF9800;fontColor=#333333;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="660" y="890" width="320" height="130" as="geometry"/>
                </mxCell>

                <!-- 14: 插入ChatSession -->
                <mxCell id="m2_14" value="14: chatSessionMapper.insert(session)&#xa;插入新会话记录到数据库" style="endArrow=classic;html=1;strokeColor=#22D3EE;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="640" y="1060" as="sourcePoint"/>
                        <mxPoint x="2060" y="1060" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m2_14_note" value="目的: 将构造好的ChatSession对象&#xa;持久化到chat_session表中" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="1070" width="230" height="35" as="geometry"/>
                </mxCell>

                <!-- 15: chat_session表插入 -->
                <mxCell id="m2_15" value="15: INSERT INTO chat_session&#xa;(id, appId, userId, title,&#xa;messageCount, modelName, ...)&#xa;VALUES (雪花ID, ?, ?, &quot;新会话4&quot;,&#xa;0, ?, NOW(), NOW(), 0)" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=11;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="640" y="1120" as="sourcePoint"/>
                        <mxPoint x="2060" y="1120" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m2_15_note" value="目的: 向chat_session表写入一条新会话记录，&#xa;messageCount初始为0(尚无消息)，&#xa;createTime/updateTime由数据库自动填充，&#xa;isDelete默认为0(未删除)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="1130" width="320" height="60" as="geometry"/>
                </mxCell>

                <!-- 16: 返回插入成功 -->
                <mxCell id="m2_16" value="16: 返回插入成功 (1 row affected)" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=13;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="2060" y="1210" as="sourcePoint"/>
                        <mxPoint x="640" y="1210" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- 17: 返回sessionId -->
                <mxCell id="m2_17" value="17: 返回 session.getId() (sessionId)" style="endArrow=classic;html=1;strokeColor=#22D3EE;strokeWidth=2;fontSize=13;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="640" y="1270" as="sourcePoint"/>
                        <mxPoint x="440" y="1270" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m2_17_note" value="目的: Service层返回新创建会话的雪花ID，&#xa;供前端后续对话时使用" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="460" y="1280" width="250" height="35" as="geometry"/>
                </mxCell>

                <!-- 18: Controller返回统一响应 -->
                <mxCell id="m2_18" value="18: 返回 BaseResponse&lt;Long&gt;&#xa;{code:0, data: sessionId}" style="endArrow=classic;html=1;strokeColor=#27BC9F;strokeWidth=2;fontSize=12;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="440" y="1340" as="sourcePoint"/>
                        <mxPoint x="255" y="1340" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m2_18_note" value="目的: Controller将sessionId封装为统一响应&#xa;格式BaseResponse返回，code=0表示成功" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="260" y="1350" width="270" height="35" as="geometry"/>
                </mxCell>

                <!-- 19: 前端跳转到对话页面 -->
                <mxCell id="m2_19" value="19: 收到sessionId，跳转到对话页面" style="endArrow=classic;html=1;strokeColor=#3366CC;strokeWidth=2;fontSize=13;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="255" y="1420" as="sourcePoint"/>
                        <mxPoint x="65" y="1420" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m2_19_note" value="目的: 前端使用返回的sessionId和appId&#xa;导航到该应用下的对话界面" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="70" y="1430" width="250" height="35" as="geometry"/>
                </mxCell>

                <!-- 20: 显示新会话对话页面 -->
                <mxCell id="m2_20" value="20: 显示新会话对话页面&#xa;(标题=&quot;新会话4&quot;, 消息数为0)" style="endArrow=classic;html=1;strokeColor=#3366CC;strokeWidth=2;fontSize=12;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="255" y="1490" as="sourcePoint"/>
                        <mxPoint x="65" y="1490" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m2_20_note" value="目的: 用户看到新建的空白对话界面，&#xa;可开始输入消息与AI对话" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="70" y="1500" width="250" height="35" as="geometry"/>
                </mxCell>

                <!-- ===== 方式B说明 ===== -->
                <mxCell id="branch_b" value="【方式B: 流式对话时自动创建会话】GET /app/chat/gen/code/stream" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#8B5CF6;fontColor=#666666;fontSize=13;fontStyle=1;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="60" y="1580" width="480" height="30" as="geometry"/>
                </mxCell>

                <mxCell id="m2_auto" value="21: 当sessionId为空或无效时，&#xa;自动调用上述 createChatSession 流程创建新会话，&#xa;并在SSE响应中首先发送 meta 事件 {sessionId: xxx}&#xa;告知前端新创建的会话ID，&#xa;后续对话消息在此会话中进行。&#xa;&#xa;功能: 减少用户手动创建会话的操作，&#xa;首次对话时自动建立会话上下文" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#8B5CF6;fontColor=#333333;fontSize=12;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="60" y="1620" width="480" height="130" as="geometry"/>
                </mxCell>

            </root>
        </mxGraphModel>
    </diagram>

