                </mxCell>

                <!-- 28 -->
                <mxCell id="m3_28" value="28: chatSessionMapper&#xa;.selectListByQuery(query)" style="endArrow=classic;html=1;strokeColor=#22D3EE;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
