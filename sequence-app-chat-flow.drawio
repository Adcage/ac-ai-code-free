                <!-- 35 -->
                <mxCell id="m3_35" value="35: POST /app/chat/history/page&#xa;{appId, sessionId, pageNum, pageSize}" style="endArrow=classic;html=1;strokeColor=#3366CC;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="235" y="2510" as="sourcePoint"/>
                        <mxPoint x="420" y="2510" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_35_note" value="目的: 分页请求某个会话的聊天消息记录，&#xa;支持按页码加载，避免一次性加载大量数据" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="240" y="2520" width="300" height="35" as="geometry"/>
                </mxCell>

                <!-- 36 -->
                <mxCell id="m3_36" value="36: appService&#xa;.listChatHistoryByPage&#xa;(queryRequest, loginUser)" style="endArrow=classic;html=1;strokeColor=#27BC9F;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="420" y="2570" as="sourcePoint"/>
                        <mxPoint x="620" y="2570" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_36_note" value="目的: Controller委派Service层执行分页查询业务逻辑" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="430" y="2580" width="280" height="30" as="geometry"/>
                </mxCell>

                <!-- 37 -->
                <mxCell id="m3_37_note" value="37: 校验应用存在+权限(同步骤7-9)&#xa;校验会话归属(同步骤10-12)&#xa;目的: 确保请求参数合法，用户有权访问该会话的历史消息,&#xa;复用之前的校验逻辑" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="640" y="2620" width="380" height="70" as="geometry"/>
                </mxCell>

                <!-- 38 -->
                <mxCell id="m3_38" value="38: chatHistoryMapper&#xa;.selectListByQuery(query)" style="endArrow=classic;html=1;strokeColor=#22D3EE;strokeWidth=2;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="620" y="2720" as="sourcePoint"/>
                        <mxPoint x="2060" y="2720" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_38_note" value="目的: Service层构建查询条件，&#xa;按sessionId+appId+userId查询聊天消息，&#xa;并按消息序号seqNo升序排列保证对话顺序" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="2730" width="340" height="45" as="geometry"/>
                </mxCell>

                <!-- 39 -->
                <mxCell id="m3_39" value="39: SELECT * FROM chat_history&#xa;WHERE sessionId=? AND appId=?&#xa;AND userId=? AND isDelete=0&#xa;ORDER BY seqNo ASC" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=11;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="620" y="2780" as="sourcePoint"/>
                        <mxPoint x="2060" y="2780" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_39_note" value="目的: 从chat_history表查询指定会话的所有聊天消息，&#xa;三重条件(sessionId+appId+userId)保证数据安全，&#xa;按seqNo升序确保消息按发送顺序排列，&#xa;然后内存分页返回指定页码的数据" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="2790" width="340" height="60" as="geometry"/>
                </mxCell>

                <!-- 40 -->
                <mxCell id="m3_40" value="40: 返回List&lt;ChatHistory&gt;消息列表&#xa;包含user/ai/system/tool类型消息" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=12;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="2060" y="2860" as="sourcePoint"/>
                        <mxPoint x="620" y="2860" as="targetPoint"/>
