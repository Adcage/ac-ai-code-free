                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_28_note" value="目的: Service层构建查询条件，&#xa;查询指定应用下属于当前用户的会话列表" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="2000" width="290" height="35" as="geometry"/>
                </mxCell>

                <!-- 29 -->
                <mxCell id="m3_29" value="29: SELECT * FROM chat_session&#xa;WHERE userId=? AND appId=?&#xa;AND isDelete=0&#xa;ORDER BY updateTime DESC" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=11;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="620" y="2050" as="sourcePoint"/>
                        <mxPoint x="1820" y="2050" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_29_note" value="目的: 从chat_session表查询当前用户在指定应用下的&#xa;所有未删除会话，按updateTime降序排列，&#xa;确保最近活跃的会话排在前面" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="2060" width="300" height="50" as="geometry"/>
                </mxCell>

                <!-- 30 -->
                <mxCell id="m3_30" value="30: 返回 List&lt;ChatSession&gt;&#xa;(包含会话标题、消息数、最后消息时间等)" style="endArrow=classic;html=1;strokeColor=#6FA3FF;strokeWidth=2;fontSize=12;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="1820" y="2120" as="sourcePoint"/>
                        <mxPoint x="620" y="2120" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>

                <!-- 31 -->
                <mxCell id="m3_31" value="31: 转换为List&lt;ChatSessionVO&gt;&#xa;[{id, appId, title, messageCount,&#xa;lastMessageTime, ...}]" style="endArrow=classic;html=1;strokeColor=#22D3EE;strokeWidth=2;fontSize=12;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="620" y="2180" as="sourcePoint"/>
                        <mxPoint x="420" y="2180" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_31_note" value="目的: Service将实体列表转换为VO列表，&#xa;ChatSessionVO包含前端所需的展示字段，&#xa;隐藏敏感的内部字段如isDelete等" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="430" y="2190" width="310" height="45" as="geometry"/>
                </mxCell>

                <!-- 32 -->
                <mxCell id="m3_32" value="32: 返回 BaseResponse&lt;List&lt;ChatSessionVO&gt;&gt;" style="endArrow=classic;html=1;strokeColor=#27BC9F;strokeWidth=2;fontSize=13;fontColor=#333333;dashed=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="420" y="2250" as="sourcePoint"/>
                        <mxPoint x="235" y="2250" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="m3_32_note" value="目的: Controller将VO列表封装为统一响应格式返回" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#999999;fontColor=#666666;fontSize=11;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="240" y="2260" width="300" height="30" as="geometry"/>
                </mxCell>

                <!-- 33 -->
                <mxCell id="m3_33" value="33: 渲染会话列表&#xa;(按updateTime降序，最近活跃的排最前)" style="endArrow=classic;html=1;strokeColor=#3366CC;strokeWidth=2;fontSize=12;fontColor=#333333;dashed=1;" parent="1" edge="1">
